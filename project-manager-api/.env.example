# Postgres connection string. Local example shown; in production use your
# managed Postgres URL (e.g. Neon, Supabase, Render Postgres).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_manager

# Long random string used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# Port the API listens on. Most hosts inject their own PORT — leave unset there.
PORT=8080

# Comma-separated list of allowed frontend origins for CORS.
# Local default. Production example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
